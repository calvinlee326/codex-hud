{
  "name": "codex-hud-dashboard",
  "version": "0.1.0",
  "description": "A safe, local-first terminal HUD and usage dashboard for OpenAI Codex CLI",
  "keywords": [
    "codex",
    "openai",
    "cli",
    "hud",
    "dashboard",
    "statusline",
    "terminal"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-hud": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "chokidar": "^3.6.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "smol-toml": "^1.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
